// AND (&&)
System.debug(true && true);   // true
System.debug(false && true);  // false
System.debug(true && false);  // false
System.debug(false && false); // false

// OR (||)
System.debug(true || true);   // true
System.debug(false || true);  // true
System.debug(true || false);  // true
System.debug(false || false); // false
